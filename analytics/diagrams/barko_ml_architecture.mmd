---
title: "ML-архитектура BARKO: персональный план + LLM/RAG чат"
---
flowchart LR
    subgraph clients["Клиентские сервисы"]
        direction TB
        mobile["Мобильное приложение"]
        web["Веб-приложение"]
    end

    subgraph app_servers["Серверы приложений"]
        direction TB
        web_server["Сервер веб-приложения"]
        redis["Redis<br/>• кэш плана<br/>• сессии<br/>• push-очередь"]
        api["Backend API"]
    end

    subgraph ml_risk["Оценка риска / K3"]
        direction TB
        risk_features["Feature store K3<br/>• C-BARQ признаки<br/>• feature schema"]
        risk_score["RiskScore<br/>• LogisticRegression baseline<br/>• risk score<br/>• 1 / 7 / 30 / 90 дней"]
        risk_params["Параметры K3<br/>• model.pkl<br/>• calibration"]
        risk_features --> risk_score
        risk_params -.->|inference| risk_score
    end

    subgraph ml_chat["Чат-бот / K5"]
        direction TB
        chat_features["Feature store K5<br/>• контекст питомца<br/>• RAG chunks / embeddings"]
        llm_rag["LLM + RAG<br/>• MongoDB knowledge base<br/>• safety guardrails"]
        chat_params["Параметры K5<br/>• prompts<br/>• retrieval config"]
        chat_features --> llm_rag
        chat_params -.->|inference| llm_rag
    end

    subgraph storage_ops["Хранилище и операции"]
        direction TB
        db[("PostgreSQL<br/>• профили питомцев<br/>• анкеты / прогресс<br/>• история чата")]
        data["C-BARQ subsets<br/>• custdev<br/>• динамика ответов"]
        incidents["Data drift, prompt incidents"]
    end

    subgraph monitoring["Мониторинг"]
        direction TB
        prometheus["Prometheus<br/>• ROC-AUC / PR-AUC<br/>• Recall@k / CSAT<br/>• latency / safety"]
        grafana["Grafana<br/>• ML / LLM дашборды<br/>• SLO и алерты"]
        prometheus -->|query| grafana
    end

    subgraph source["Исходный код"]
        direction TB
        github["GitHub<br/>• mobile / web / API<br/>• K3 / K5 сервисы<br/>• infra, CI/CD"]
    end

    mobile -->|"анкета / чат"| redis
    redis <-->|"кэш / сессии"| api
    redis -->|"план / push"| mobile
    web -->|админка| web_server
    web_server -->|API| api
    api -->|профиль| risk_score
    risk_score -->|"план + прогресс"| db
    api -->|"обновление кэша"| redis
    api -->|"вопрос + контекст"| llm_rag
    llm_rag -->|ответ| api
    llm_rag -->|история| db
    db -.->|контекст| api

    db -.->|"обучение / дообучение<br/>данные питомца"| risk_score
    data -.->|"обучение / дообучение<br/>C-BARQ"| risk_score
    db -.->|"обучение / дообучение<br/>данные питомца"| llm_rag
    data -.->|"обучение / дообучение<br/>C-BARQ"| llm_rag

    data -.->|train / export| risk_params
    data -.->|fine-tune / index| chat_params

    risk_score -->|"ML logs"| prometheus
    llm_rag -->|"LLM/RAG logs"| prometheus
    api -->|API metrics| prometheus
    grafana -->|alerts| incidents
    web -->|дашборды| grafana
    incidents -.->|issues / fix backlog| github
    github -.->|CI/CD deploy| api
    github -.->|CI/CD deploy| web_server
    github -.->|CI/CD deploy| risk_score
    github -.->|CI/CD deploy| llm_rag
    github -.->|release pipeline| mobile

